# Database Configuration
# DB_HOST=localhost when running the API on your machine (npm run start:dev).
# docker-compose.yml overrides DB_HOST to "db" for the api service.
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# JWT Configuration (RS256 — asymmetric)
# Generate dev keys: openssl genrsa -out keys/jwt-private.pem 2048 && openssl rsa -in keys/jwt-private.pem -pubout -out keys/jwt-public.pem
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# Application
NODE_ENV=
PORT=
FRONTEND_URL=http://localhost:5173

# Initial admin (npm run db:seed) — only created if email does not exist yet
ADMIN_EMAIL=
# Quote passwords containing $ so Docker Compose does not treat $ as variable interpolation

ADMIN_PASSWORD=

# Bcrypt Configuration
SALT_ROUNDS=12